{
    "name": "innonazarene/dbm-salary-parser",
    "description": "Salary Grade schedule parser. Look up monthly salaries by grade and step.",
    "keywords": [
        "salary grade"
    ],
    "homepage": "https://github.com/innonazarene/dbm-salary-parser",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Tom Ramos Pedales",
            "email": "pedales.rustom@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "smalot/pdfparser": "^2.0"
    },
    "suggest": {
        "smalot/pdfparser": "Required if pdftotext (poppler-utils) is not installed on your system"
    },
    "autoload": {
        "psr-4": {
            "PhSalaryGrade\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhSalaryGrade\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}